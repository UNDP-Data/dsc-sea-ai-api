# Azure OpenAI
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_CHAT_MODEL=
AZURE_OPENAI_EMBED_MODEL=

# Azure Blob Storage
# Preferred if you already have a full SAS URL
STORAGE_SAS_URL=
STORAGE_ACCOUNT_NAME=
STORAGE_ACCOUNT_KEY=
# Optional alternative to STORAGE_ACCOUNT_KEY
STORAGE_SAS_TOKEN=

# API Authentication
API_KEY=

# KG Tester (optional)
# Used to prefill "Remote API Base URL" in /kg-tester.
KG_TESTER_REMOTE_API_BASE_URL=
