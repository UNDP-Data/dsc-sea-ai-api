# Azure OpenAI
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_CHAT_MODEL=
AZURE_OPENAI_EMBED_MODEL=

# Azure Blob Storage
# Preferred if you already have a full SAS URL
STORAGE_SAS_URL=
STORAGE_ACCOUNT_NAME=
STORAGE_ACCOUNT_KEY=
# Optional alternative to STORAGE_ACCOUNT_KEY
STORAGE_SAS_TOKEN=

# API Authentication
API_KEY=

# /model streaming safety timeouts (optional, positive seconds)
# Invalid or non-positive values fall back to internal defaults.
MODEL_GRAPH_TIMEOUT_SECONDS=120
MODEL_STREAM_IDLE_TIMEOUT_SECONDS=90
MODEL_TOOLS_PREP_TIMEOUT_SECONDS=45
MODEL_STREAM_WATCHDOG_SECONDS=150
MODEL_PUBLICATION_RETRIEVAL_TIMEOUT_SECONDS=90
MODEL_PUBLICATION_HEARTBEAT_SECONDS=5
RETRIEVE_CHUNKS_TIMEOUT_SECONDS=60
RETRIEVE_CHUNKS_LEXICAL_TIMEOUT_SECONDS=6
RETRIEVE_CHUNKS_VARIANT_TIMEOUT_SECONDS=12

# KG Tester (optional)
# Separate frontend tester app envs.
# API key used by tester proxy to call backend.
KG_TESTER_API_KEY=
# Local backend base URL used when target=local.
KG_TESTER_LOCAL_API_BASE_URL=http://127.0.0.1:8000
# Default remote backend base URL shown in tester.
KG_TESTER_REMOTE_API_BASE_URL=https://sea-ai-api.azurewebsites.net
