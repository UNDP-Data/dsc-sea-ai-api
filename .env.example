# Azure OpenAI
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_CHAT_MODEL=
AZURE_OPENAI_EMBED_MODEL=

# Azure Blob Storage
# Preferred if you already have a full SAS URL
STORAGE_SAS_URL=
STORAGE_ACCOUNT_NAME=
STORAGE_ACCOUNT_KEY=
# Optional alternative to STORAGE_ACCOUNT_KEY
STORAGE_SAS_TOKEN=

# API Authentication
API_KEY=

# KG Tester (optional)
# Separate frontend tester app envs.
# API key used by tester proxy to call backend.
KG_TESTER_API_KEY=
# Local backend base URL used when target=local.
KG_TESTER_LOCAL_API_BASE_URL=http://127.0.0.1:8000
# Optional default remote backend base URL shown in tester.
KG_TESTER_REMOTE_API_BASE_URL=
